{
  "name": "sparxie",
  "version": "0.24.0",
  "description": "Shared Valedictorian contracts and HTTP client.",
  "author": "Keni",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KennyKeni/sparxie.git"
  },
  "bugs": {
    "url": "https://github.com/KennyKeni/sparxie/issues"
  },
  "homepage": "https://github.com/KennyKeni/sparxie#readme",
  "keywords": [
    "sparxie",
    "sdk",
    "valedictorian",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "pnpm run lint:line-limit-policy && oxlint . && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.type-tests.json",
    "lint:line-limit-policy": "node scripts/line-limit-policy.mjs",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "lefthook": "^2.1.10",
    "oxlint": "^1.68.0",
    "typescript": "^7.0.2",
    "vitest": "^2.1.9"
  }
}
